      "label": "I acknowledge that NFGA has no legal duty to provide first aid or rescue operations."
    },
    {
      "id": "facilities-equipment",
      "label": "I acknowledge that NFGA makes no warranty regarding its facilities or equipment."
    },
    {
      "id": "accept-risks",
      "label": "I accept and assume all risks connected with entering NFGA property and participating in or observing activities."
    },
    {
