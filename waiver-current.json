      "label": "I accept responsibility and liability for the conduct of my guests."
    },
    {
      "id": "laws-rules",
      "label": "I agree to follow applicable laws and all NFGA and firing-range rules."
    },
    {
      "id": "release",
      "label": "I release and agree not to sue NFGA and the released parties as stated in the agreement."
    },
    {
      "id": "indemnify",
      "label": "I agree to indemnify and hold harmless the released parties as stated in the agreement."
    },
    {
      "id": "new-hampshire-law",
      "label": "I agree that the agreement is governed by New Hampshire law and proceedings will be brought in New Hampshire courts."
    },
    {
      "id": "severability",
      "label": "I agree that any invalid or unenforceable portion will not invalidate the remaining provisions."
    },
    {
      "id": "continuing-effect",
      "label": "I agree that the agreement remains in effect indefinitely and applies to every occasion I enter NFGA property."
    }
  ],

